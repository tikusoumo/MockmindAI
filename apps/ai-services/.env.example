# Application Settings
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS Settings
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001

# LiveKit Configuration
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here

# Google API Configuration
GOOGLE_API_KEY=your_google_api_key_here

# Local AI Models (Llama, Whisper, Kokoro)
# Set to true to override cloud providers and use local models
USE_LOCAL_AI=false

# LiveKit worker process tuning
LIVEKIT_NUM_IDLE_PROCESSES=1
LIVEKIT_INITIALIZE_PROCESS_TIMEOUT=60
LIVEKIT_JOB_MEMORY_WARN_MB=1200
LIVEKIT_JOB_MEMORY_LIMIT_MB=0
