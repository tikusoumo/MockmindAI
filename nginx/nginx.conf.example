map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

server {
    listen 80;
    server_name local.voiceagent.test www.local.voiceagent.test;
    # TODO: Change to your real domain and add SSL when ready

    # Proper IP proxy headers
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # Map /api to NestJS Backend (Port 8000)
    location /api/ {
        proxy_pass http://api:8000;

        # Support WebSocket for any socket.io/Nest events if applicable
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }

    # Map everything else to Next.js Frontend (Port 3000)
    location / {
        proxy_pass http://frontend:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }

    # HMR WebSocket for Next.js Hot Module Replacement
    location /_next/webpack-hmr {
        proxy_pass http://frontend:3000/_next/webpack-hmr;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 86400;
    }
}

# LiveKit WebRTC sub-domain block
server {
    listen 80;
    server_name livekit.local.voiceagent.test;
    # TODO: Change to your real domain and add SSL when ready

    # Proper IP proxy headers
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    location / {
        proxy_pass http://livekit:7880;

        # CRITICAL: WebSockets are heavily required for LiveKit RTC
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 86400; # Keep socket alive
    }
}
